/* ── Корневая обёртка ── */
#app {
  min-height: 100vh;
}

/* ── Двухколоночная сетка ── */
.main-container {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 2rem;
  padding: 2rem;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

/* ── Лента постов ── */
.feed {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

/* ── Сайдбар ── */
.sidebar {
  position: sticky;
  top: 2rem;
  max-height: calc(100vh - 4rem);
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: transparent transparent;
  transition: scrollbar-color 0.3s;
}

.sidebar:hover {
  scrollbar-color: var(--muted-foreground) var(--muted);
}

.sidebar::-webkit-scrollbar { width: 8px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }
.sidebar::-webkit-scrollbar-thumb { background: transparent; border-radius: 4px; }
.sidebar:hover::-webkit-scrollbar-track { background: var(--muted); }
.sidebar:hover::-webkit-scrollbar-thumb { background: var(--muted-foreground); }
.sidebar:hover::-webkit-scrollbar-thumb:hover { background: var(--foreground); }

/* ── Кнопка развернуть/свернуть (только мобильные) ── */
.expand-toggle,
.collapse-toggle {
  display: none;
}

/* ── Страница поста ── */
.post-view {
  max-width: 900px;
  margin: 0 auto;
  padding: 2rem;
}

/* ── Страница профиля ── */
.profile-edit {
  max-width: 800px;
  margin: 0 auto;
  padding: 20px;
}

/* ── Страницы редактора и авторизации ── */
.editor-page,
.auth-page {
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem;
}

/* ── Мобильная версия ── */
@media (max-width: 768px) {
  .main-container {
    grid-template-columns: 1fr;
    padding: 1rem;
    gap: 1rem;
    max-width: 100vw;
  }

  .feed {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
  }

  .sidebar {
    order: -1;
    display: none;
    max-width: 100%;
  }

  .sidebar.expanded {
    display: block;
  }

  .expand-toggle {
    display: block;
    width: 100%;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    cursor: pointer;
    text-align: center;
    font-weight: var(--font-weight-medium);
    font-family: inherit;
    font-size: 0.875rem;
  }

  .collapse-toggle {
    display: block;
    width: 100%;
    background: var(--blue);
    color: #ffffff;
    border: 1px solid var(--blue);
    border-radius: var(--radius);
    padding: 0.75rem;
    cursor: pointer;
    text-align: center;
    font-weight: var(--font-weight-medium);
    font-family: inherit;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .post-view {
    padding: 1rem;
  }

  .post-navigation {
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-link {
    flex: 1;
    text-align: center;
  }

  .pagination-controls {
    flex-direction: row;
    justify-content: center;
    gap: 1rem;
  }
}
